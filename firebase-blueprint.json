{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "Information entered by a user subscribing on the landing page",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        },
        "country": {
          "type": "object"
        },
        "description": {
          "type": "string"
        },
        "experience": {
          "type": "string"
        },
        "joinMastermind": {
          "type": "boolean"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "synced": {
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "name",
        "phone",
        "timestamp"
      ]
    }
  },
  "firestore": {
    "leads/{leadId}": {
      "schema": "Lead",
      "description": "Collection of incoming subscriber leads"
    }
  }
}
